.venv/
__pycache__/
*.py[cod]
.DS_Store
*.swp
~$*

# Local source videos and generated run artifacts stay on disk, not in git.
inputs/*
!inputs/.gitkeep
runs/*
!runs/.gitkeep

# Guardrails in case ad-hoc media files are written outside runs/.
*.mp4
*.jpg
*.jpeg
*.png
*.trf

# Third-party experiments stay local unless explicitly documented and committed.
third_party/*
!third_party/README.md
